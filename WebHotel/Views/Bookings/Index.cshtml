@model IEnumerable<WebHotel.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<div class="page-header">
    <h1><i class="bi bi-calendar-check"></i> Bookings</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> New Booking
    </a>
</div>

<form method="get" asp-action="Index" class="card shadow-soft mb-3">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-8 col-lg-9">
                <label for="booking-search" class="form-label mb-1">Search Bookings</label>
                <input id="booking-search"
                       name="search"
                       value="@ViewData["CurrentSearch"]"
                       class="form-control"
                       placeholder="Search by booking ID, customer, room, date, paid, or unpaid" />
            </div>
            <div class="col-md-4 col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Search
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Customer</th>
                <th>Room</th>
                <th>Check-in</th>
                <th>Check-out</th>
                <th>Total</th>
                <th>Payment</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold text-muted small">Booking ID #@item.Id</div>
                            <i class="bi bi-person text-muted"></i>
                            @(item.Customer?.FullName ?? item.Customer?.Email ?? "-")
                            <div class="small text-muted">@(item.Customer?.Email ?? $"Customer ID #{item.CustomerId}")</div>
                        </td>
                        <td>
                            <div class="fw-bold">@(item.Room?.Number ?? "-")</div>
                            <div class="small text-muted">Room ID #@item.RoomId</div>
                        </td>
                        <td>@item.CheckIn.ToString("MMM dd, yyyy")</td>
                        <td>@item.CheckOut.ToString("MMM dd, yyyy")</td>
                        <td class="fw-bold">@item.TotalPrice.ToString("C")</td>
                        <td>
                            @if (item.IsPaid)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Paid</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="bi bi-clock"></i> Unpaid</span>
                            }
                        </td>
                        <td class="text-muted">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="text-end action-links">
                            <a class="btn-action-edit" asp-action="Edit" asp-route-id="@item.Id">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a class="btn-action-detail" asp-action="Details" asp-route-id="@item.Id">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a class="btn-action-delete" asp-action="Delete" asp-route-id="@item.Id">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <i class="bi bi-search"></i> No bookings matched your search.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
