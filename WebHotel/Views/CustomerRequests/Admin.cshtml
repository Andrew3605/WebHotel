@model IEnumerable<WebHotel.Models.CustomerRequest>
@using WebHotel.Models

@{
    ViewData["Title"] = "Customer Requests";
    var currentSearch = ViewBag.Search as string;
    var selectedStatus = ViewBag.SelectedStatus as RequestStatus?;
}

<div class="page-header">
    <h1><i class="bi bi-inbox"></i> Customer Requests</h1>
</div>

<!-- Filter + bulk clear -->
<div class="card mb-4">
    <div class="card-body d-flex align-items-center gap-2 flex-wrap">
        <span class="fw-bold me-2"><i class="bi bi-funnel"></i> Filter:</span>
        <a asp-action="Admin" asp-route-search="@currentSearch" class="btn btn-sm btn-outline-primary">All</a>
        <a asp-action="Admin" asp-route-status="Pending" asp-route-search="@currentSearch" class="btn btn-sm btn-outline-warning">
            <i class="bi bi-hourglass-split"></i> Pending
        </a>
        <a asp-action="Admin" asp-route-status="Approved" asp-route-search="@currentSearch" class="btn btn-sm btn-outline-success">
            <i class="bi bi-check-circle"></i> Approved
        </a>
        <a asp-action="Admin" asp-route-status="Rejected" asp-route-search="@currentSearch" class="btn btn-sm btn-outline-danger">
            <i class="bi bi-x-circle"></i> Rejected
        </a>

        <form asp-action="Admin" method="get" class="d-flex align-items-center gap-2 flex-wrap ms-lg-3">
            @if (selectedStatus.HasValue)
            {
                <input type="hidden" name="status" value="@selectedStatus.Value" />
            }
            <input type="text"
                   name="search"
                   value="@currentSearch"
                   class="form-control form-control-sm"
                   style="width: 220px;"
                   placeholder="Search requests..." />
            <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-search"></i> Search
            </button>
        </form>

        <div class="ms-auto">
            <form asp-action="ClearResolved" method="post" class="d-inline">
                <input type="hidden" name="days" value="30" />
                <button class="btn btn-sm btn-outline-danger"
                        title="Delete Approved/Rejected requests older than 30 days"
                        onclick="return confirm('Delete resolved requests older than 30 days?');">
                    <i class="bi bi-trash3"></i> Clear resolved ≥30d
                </button>
            </form>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="bi bi-inbox"></i>
        <p>No requests found.</p>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Customer</th>
                    <th>Type</th>
                    <th>Room</th>
                    <th>Check-in</th>
                    <th>Check-out</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th style="max-width:220px">Message</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td class="text-muted">@r.Id</td>
                        <td>@(r.CustomerId?.ToString() ?? "-")</td>
                        <td><span class="badge bg-primary">@r.Type</span></td>
                        <td class="fw-semibold">@(r.RoomId?.ToString() ?? "-")</td>
                        <td>@(r.CheckIn?.ToString("MMM dd, yyyy") ?? "-")</td>
                        <td>@(r.CheckOut?.ToString("MMM dd, yyyy") ?? "-")</td>
                        <td>
                            @switch (r.Status)
                            {
                                case RequestStatus.Pending:
                                    <span class="badge status-badge-pending"><i class="bi bi-hourglass-split"></i> Pending</span>
                                    break;
                                case RequestStatus.Approved:
                                    <span class="badge status-badge-approved"><i class="bi bi-check-circle"></i> Approved</span>
                                    break;
                                case RequestStatus.Rejected:
                                    <span class="badge status-badge-rejected"><i class="bi bi-x-circle"></i> Rejected</span>
                                    break;
                            }
                        </td>
                        <td class="text-muted small">@r.CreatedAt.ToString("MMM dd, HH:mm")</td>
                        <td style="max-width:220px" class="text-muted small">@r.Message</td>
                        <td class="text-end text-nowrap">
                            @if (r.Status == RequestStatus.Pending)
                            {
                                <form asp-action="Approve" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline ms-1">
                                    <input type="hidden" name="id" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-warning">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </form>
                            }
                            <form asp-action="Delete" method="post" class="d-inline ms-1">
                                <input type="hidden" name="id" value="@r.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete this request?');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
