@model WebHotel.Models.Customer

@{
    ViewData["Title"] = "Customer Details";
}

<div class="page-header">
    <h1><i class="bi bi-person-vcard"></i> Customer Details</h1>
    <div class="action-links">
        <a class="btn-action-edit" asp-action="Edit" asp-route-id="@Model.Id">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a class="btn-action-detail" asp-action="ResetPassword" asp-route-id="@Model.Id">
            <i class="bi bi-key"></i> Reset Password
        </a>
    </div>
</div>

<div class="card shadow-soft">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</div>
