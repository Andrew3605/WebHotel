@model WebHotel.ViewModels.PaginatedList<WebHotel.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="page-header">
    <h1><i class="bi bi-people"></i> Customers</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus"></i> Add Customer
    </a>
</div>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <div class="alert alert-success shadow-soft" role="alert">
        <i class="bi bi-check-circle"></i> @statusMessage
    </div>
}

<form method="get" asp-action="Index" class="card shadow-soft mb-3">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-8 col-lg-9">
                <label for="customer-search" class="form-label mb-1">Search Customers</label>
                <input id="customer-search"
                       name="search"
                       value="@ViewData["CurrentSearch"]"
                       class="form-control"
                       placeholder="Search by customer ID, name, email, or phone" />
            </div>
            <div class="col-md-4 col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Search
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">@Model.TotalCount customer(s) found</small>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold text-muted small">ID #@item.Id</div>
                            <i class="bi bi-person-circle text-primary"></i>
                            <span class="fw-semibold">@item.FullName</span>
                        </td>
                        <td><i class="bi bi-envelope text-muted"></i> @item.Email</td>
                        <td><i class="bi bi-telephone text-muted"></i> @(string.IsNullOrWhiteSpace(item.Phone) ? "-" : item.Phone)</td>
                        <td class="text-end action-links">
                            <a class="btn-action-edit" asp-action="Edit" asp-route-id="@item.Id">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a class="btn-action-detail" asp-action="Details" asp-route-id="@item.Id">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a class="btn-action-detail" asp-action="ResetPassword" asp-route-id="@item.Id">
                                <i class="bi bi-key"></i> Reset Password
                            </a>
                            <a class="btn-action-delete" asp-action="Delete" asp-route-id="@item.Id">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center py-4 text-muted">
                        <i class="bi bi-search"></i> No customers matched your search.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@ViewData["CurrentSearch"]"
                   asp-route-page="@(Model.PageIndex - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@ViewData["CurrentSearch"]"
                       asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" asp-action="Index"
                   asp-route-search="@ViewData["CurrentSearch"]"
                   asp-route-page="@(Model.PageIndex + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
