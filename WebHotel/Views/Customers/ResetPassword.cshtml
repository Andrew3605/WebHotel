@model WebHotel.ViewModels.AdminResetCustomerPasswordVm

@{
    ViewData["Title"] = "Reset Customer Password";
}

<div class="page-header">
    <h1><i class="bi bi-key"></i> Reset Customer Password</h1>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-soft">
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="text-muted small text-uppercase">Customer</div>
                    <div class="fs-5 fw-semibold">@Model.CustomerName</div>
                    <div class="text-muted">@Model.CustomerEmail</div>
                    <div class="mt-2">
                        <span class="badge @(Model.HasLinkedAccount ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                            @(Model.HasLinkedAccount ? $"Linked login: {Model.LinkedLoginEmail}" : "No linked login account")
                        </span>
                    </div>
                </div>

                @if (!Model.HasLinkedAccount)
                {
                    <div class="alert alert-warning" role="alert">
                        This customer record is not linked to an Identity login yet, so the password cannot be reset here.
                    </div>
                }

                <form asp-action="ResetPassword" method="post">
                    <input asp-for="CustomerId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        @if (Model.HasLinkedAccount)
                        {
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check2-circle"></i> Update Password
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-primary" disabled>
                                <i class="bi bi-check2-circle"></i> Update Password
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Back
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
