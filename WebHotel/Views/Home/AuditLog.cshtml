@model WebHotel.ViewModels.PaginatedList<WebHotel.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Log";
}

<h2 class="mb-4"><i class="bi bi-journal-text"></i> Audit Log</h2>

<form method="get" asp-action="AuditLog" class="card shadow-soft mb-3">
    <div class="card-body p-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-8 col-lg-9">
                <label for="audit-search" class="form-label mb-1">Search Audit Log</label>
                <input id="audit-search" name="search" value="@ViewData["CurrentSearch"]"
                       class="form-control" placeholder="Search by action, entity, user, role, or details" />
            </div>
            <div class="col-md-4 col-lg-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">
                    <i class="bi bi-search"></i> Search
                </button>
                <a asp-action="AuditLog" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-between align-items-center mb-2">
    <small class="text-muted">@Model.TotalCount log entries</small>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle table-sm">
        <thead>
            <tr>
                <th>When</th>
                <th>Action</th>
                <th>Entity</th>
                <th>ID</th>
                <th>User</th>
                <th>Role</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td class="text-nowrap small">@log.PerformedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td>
                        <span class="badge @(log.Action.Contains("Delete") ? "bg-danger" : log.Action.Contains("Create") ? "bg-success" : log.Action.Contains("Approve") ? "bg-primary" : log.Action.Contains("Reject") ? "bg-warning text-dark" : "bg-secondary")">
                            @log.Action
                        </span>
                    </td>
                    <td>@log.EntityType</td>
                    <td>@(log.EntityId?.ToString() ?? "-")</td>
                    <td class="small">@log.PerformedBy</td>
                    <td>
                        <span class="badge @(log.UserRole == "Admin" ? "bg-dark" : "bg-info")">@log.UserRole</span>
                    </td>
                    <td class="small text-muted" style="max-width:300px;overflow:hidden;text-overflow:ellipsis;">@log.Details</td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">No audit entries yet.</td></tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" asp-action="AuditLog" asp-route-search="@ViewData["CurrentSearch"]" asp-route-page="@(Model.PageIndex - 1)">Previous</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="AuditLog" asp-route-search="@ViewData["CurrentSearch"]" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" asp-action="AuditLog" asp-route-search="@ViewData["CurrentSearch"]" asp-route-page="@(Model.PageIndex + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
