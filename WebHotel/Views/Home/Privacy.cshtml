@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="info-page mx-auto">
    <div class="page-header">
        <h1><i class="bi bi-shield-check"></i> Privacy Policy</h1>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <p class="lead">
                This web application is a demonstration project built for learning and portfolio purposes.
                It stores standard customer and booking information required for the demo workflow, but it is not intended for processing real-world sensitive payment data.
            </p>

            <h5 class="fw-bold mt-4 mb-3">How the demo works:</h5>

            <ul>
                <li>Customer profile details such as name, email, phone number, booking details, and request notes are stored for demonstration.</li>
                <li>Passwords are handled through ASP.NET Core Identity and are not stored in plain text.</li>
                <li>The payment experience is a simulated demo workflow. Full card number and CVV are not saved to the database.</li>
                <li>Bookings, requests, and payment records exist to demonstrate system functionality.</li>
            </ul>

            <p class="text-muted mt-4 mb-0">
                <i class="bi bi-info-circle"></i>
                This page is accessible to all users to explain how the demo handles account, booking, and payment information.
            </p>
        </div>
    </div>
</div>
