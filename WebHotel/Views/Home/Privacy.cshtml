@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="info-page mx-auto">
    <div class="page-header">
        <h1><i class="bi bi-shield-check"></i> Privacy Policy</h1>
    </div>

    <div class="card">
        <div class="card-body p-4">
            <p class="lead">
                This educational web application is developed as part of SOFT703 Web Applications Development.
                It does not collect or share real personal data.
            </p>

            <h5 class="fw-bold mt-4 mb-3">How the demo works:</h5>

            <ul>
                <li>Customer details (name, email, phone) are stored only for demonstration.</li>
                <li>Passwords are handled securely through ASP.NET Identity.</li>
                <li>Bookings and requests exist for testing system functionality.</li>
            </ul>

            <p class="text-muted mt-4 mb-0">
                <i class="bi bi-info-circle"></i>
                This page is accessible to all users to satisfy privacy and navigation requirements.
            </p>
        </div>
    </div>
</div>
