@model WebHotel.ViewModels.PaymentVm
@{
    ViewData["Title"] = "Pay for Booking";
}

<div class="page-header">
    <h1><i class="bi bi-credit-card"></i> Pay for Booking</h1>
</div>

<div class="row g-4">
    <!-- Booking Summary -->
    <div class="col-lg-5">
        <div class="payment-card mb-4">
            <div class="mb-3">
                <span class="label">Booking</span>
                <div class="value">#@Model.BookingId</div>
            </div>
            <div class="mb-3">
                <span class="label">Room</span>
                <div class="value"><i class="bi bi-door-open"></i> @Model.RoomNumber</div>
            </div>
            <div class="row mb-3">
                <div class="col-6">
                    <span class="label">Check-in</span>
                    <div class="value">@Model.CheckIn.ToString("MMM dd, yyyy")</div>
                </div>
                <div class="col-6">
                    <span class="label">Check-out</span>
                    <div class="value">@Model.CheckOut.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.2);" />
            <div>
                <span class="label">Total Amount</span>
                <div class="total-price">@Model.TotalPrice.ToString("C")</div>
            </div>
        </div>
    </div>

    <!-- Payment Form -->
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-light">
                <i class="bi bi-lock-fill text-success"></i> Secure Payment
            </div>
            <div class="card-body">
                <form asp-action="Pay" method="post" class="row g-3">
                    <input type="hidden" asp-for="BookingId" />
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="NameOnCard" class="form-label fw-semibold">Name on Card</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="NameOnCard" class="form-control" placeholder="John Doe" />
                        </div>
                        <span asp-validation-for="NameOnCard" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CardNumber" class="form-label fw-semibold">Card Number</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                            <input asp-for="CardNumber" class="form-control" inputmode="numeric" placeholder="1234 5678 9012 3456" />
                        </div>
                        <span asp-validation-for="CardNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ExpMonth" class="form-label fw-semibold">Month</label>
                        <input asp-for="ExpMonth" class="form-control" placeholder="MM" />
                        <span asp-validation-for="ExpMonth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ExpYear" class="form-label fw-semibold">Year</label>
                        <input asp-for="ExpYear" class="form-control" placeholder="YYYY" />
                        <span asp-validation-for="ExpYear" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Cvv" class="form-label fw-semibold">CVV</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                            <input asp-for="Cvv" class="form-control" inputmode="numeric" placeholder="123" />
                        </div>
                        <span asp-validation-for="Cvv" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mt-4">
                        <button class="btn btn-success btn-lg w-100">
                            <i class="bi bi-lock-fill"></i> Pay @Model.TotalPrice.ToString("C")
                        </button>
                        <a asp-controller="Bookings" asp-action="My" class="btn btn-outline-secondary w-100 mt-2">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
