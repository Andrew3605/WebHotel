@model WebHotel.ViewModels.PaymentVm
@using WebHotel.ViewModels

@{
    ViewData["Title"] = "Booking Payment";
}

<div class="page-header">
    <h1><i class="bi bi-credit-card-2-front"></i> Booking Payment</h1>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="payment-card mb-4">
            <div class="mb-3">
                <span class="label">Booking</span>
                <div class="value">#@Model.BookingId</div>
            </div>
            <div class="mb-3">
                <span class="label">Room</span>
                <div class="value"><i class="bi bi-door-open"></i> @Model.RoomNumber</div>
            </div>
            <div class="row mb-3">
                <div class="col-6">
                    <span class="label">Check-in</span>
                    <div class="value">@Model.CheckIn.ToString("MMM dd, yyyy")</div>
                </div>
                <div class="col-6">
                    <span class="label">Check-out</span>
                    <div class="value">@Model.CheckOut.ToString("MMM dd, yyyy")</div>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.2);" />
            <div class="d-flex justify-content-between mb-2">
                <span class="label">Room total</span>
                <strong>@Model.RoomTotal.ToString("C")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="label">Extra charges</span>
                <strong>@Model.ExtraCharges.ToString("C")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="label">Paid to date</span>
                <strong>@Model.PaidToDate.ToString("C")</strong>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="label">Suggested deposit</span>
                <strong>@Model.DepositAmount.ToString("C")</strong>
            </div>
            <hr style="border-color: rgba(255,255,255,0.2);" />
            <div>
                <span class="label">Balance due</span>
                <div class="total-price">@Model.BalanceDue.ToString("C")</div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header bg-light">
                <i class="bi bi-shield-lock text-success"></i> Demo Checkout
            </div>
            <div class="card-body">
                <div class="alert alert-info small">
                    This is a demo payment workflow. Full card details are used only to simulate checkout and are not persisted to the database.
                </div>

                <form asp-action="Pay" method="post" class="row g-3">
                    <input type="hidden" asp-for="BookingId" />
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="PaymentOption" class="form-label fw-semibold"></label>
                        <select asp-for="PaymentOption" class="form-select" asp-items="Html.GetEnumSelectList<BookingPaymentOption>()"></select>
                        <div class="form-text">
                            @if (Model.HasPreviousPayments)
                            {
                                <text>Deposit is only available before any payment has been recorded. You can settle the remaining balance here.</text>
                            }
                            else
                            {
                                <text>Start with a 20% deposit or pay the full outstanding balance.</text>
                            }
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="NameOnCard" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input asp-for="NameOnCard" class="form-control" placeholder="John Doe" />
                        </div>
                        <span asp-validation-for="NameOnCard" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="CardNumber" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                            <input asp-for="CardNumber" class="form-control" inputmode="numeric" placeholder="4242 4242 4242 4242" />
                        </div>
                        <span asp-validation-for="CardNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ExpMonth" class="form-label fw-semibold"></label>
                        <input asp-for="ExpMonth" class="form-control" placeholder="MM" />
                        <span asp-validation-for="ExpMonth" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ExpYear" class="form-label fw-semibold"></label>
                        <input asp-for="ExpYear" class="form-control" placeholder="YYYY" />
                        <span asp-validation-for="ExpYear" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Cvv" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input asp-for="Cvv" class="form-control" inputmode="numeric" placeholder="123" />
                        </div>
                        <span asp-validation-for="Cvv" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mt-4">
                        <button class="btn btn-success btn-lg w-100">
                            <i class="bi bi-check2-circle"></i> Continue Payment
                        </button>
                        <a asp-action="Statement" asp-route-bookingId="@Model.BookingId" class="btn btn-outline-secondary w-100 mt-2">
                            View Booking Statement
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
