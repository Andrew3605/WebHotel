@model WebHotel.ViewModels.BookingStatementVm
@using WebHotel.Models

@{
    ViewData["Title"] = "Booking Statement";
}

<div class="page-header">
    <h1><i class="bi bi-receipt"></i> Booking Statement</h1>
</div>

@if (TempData["PaymentOk"] is string msg)
{
    <div class="alert alert-success d-flex align-items-center">
        <i class="bi bi-check-circle-fill me-2"></i> @msg
    </div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="text-muted small text-uppercase">Booking</div>
                        <h4 class="mb-0">#@Model.BookingId</h4>
                    </div>
                    @if (Model.IsPaid)
                    {
                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Settled</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> Balance Due</span>
                    }
                </div>

                <div class="mb-3">
                    <div class="small text-muted text-uppercase">Guest</div>
                    <div class="fw-semibold">@Model.CustomerName</div>
                    <div class="text-muted small">@Model.CustomerEmail</div>
                </div>

                <div class="mb-3">
                    <div class="small text-muted text-uppercase">Room</div>
                    <div class="fw-semibold">Room @Model.RoomNumber</div>
                    <div class="text-muted small">@Model.CheckIn.ToString("MMM dd, yyyy") - @Model.CheckOut.ToString("MMM dd, yyyy")</div>
                </div>

                <hr />

                <div class="d-flex justify-content-between mb-2">
                    <span>Room total</span>
                    <strong>@Model.RoomTotal.ToString("C")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Front desk charges</span>
                    <strong>@Model.ExtraCharges.ToString("C")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Payments received</span>
                    <strong class="text-success">@Model.PaymentsReceived.ToString("C")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Refunds</span>
                    <strong class="text-danger">@Model.RefundTotal.ToString("C")</strong>
                </div>

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Balance due</span>
                    <div class="fs-4 fw-bold text-primary">@Model.BalanceDue.ToString("C")</div>
                </div>

                @if (!Model.IsPaid)
                {
                    <a asp-action="Pay" asp-route-bookingId="@Model.BookingId" class="btn btn-success w-100 mt-4">
                        <i class="bi bi-credit-card"></i> Pay Online
                    </a>
                }

                @if (Model.CanManageFrontDesk)
                {
                    <a asp-controller="RoomService" asp-action="Order" asp-route-bookingId="@Model.BookingId"
                       class="btn btn-outline-primary w-100 mt-2">
                        <i class="bi bi-cup-hot"></i> Room Service
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        @if (Model.CanManageFrontDesk)
        {
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <i class="bi bi-pc-display-horizontal"></i> Front Desk Entry
                </div>
                <div class="card-body">
                    <form asp-action="DeskEntry" method="post" class="row g-3">
                        <input type="hidden" asp-for="FrontDeskEntry.BookingId" />

                        <div class="col-md-4">
                            <label asp-for="FrontDeskEntry.Type" class="form-label fw-semibold"></label>
                            <select asp-for="FrontDeskEntry.Type" class="form-select" asp-items="Html.GetEnumSelectList<PaymentEntryType>()"></select>
                            <span asp-validation-for="FrontDeskEntry.Type" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FrontDeskEntry.Method" class="form-label fw-semibold"></label>
                            <select asp-for="FrontDeskEntry.Method" class="form-select" asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
                            <span asp-validation-for="FrontDeskEntry.Method" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FrontDeskEntry.Amount" class="form-label fw-semibold"></label>
                            <input asp-for="FrontDeskEntry.Amount" class="form-control" />
                            <span asp-validation-for="FrontDeskEntry.Amount" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="FrontDeskEntry.Description" class="form-label fw-semibold"></label>
                            <input asp-for="FrontDeskEntry.Description" class="form-control" placeholder="Breakfast package, minibar, POS settlement..." />
                            <span asp-validation-for="FrontDeskEntry.Description" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="FrontDeskEntry.Reference" class="form-label fw-semibold"></label>
                            <input asp-for="FrontDeskEntry.Reference" class="form-control" placeholder="POS-1024" />
                            <span asp-validation-for="FrontDeskEntry.Reference" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary">
                                <i class="bi bi-plus-circle"></i> Add Entry
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header bg-light d-flex justify-content-between align-items-center">
                <span><i class="bi bi-clock-history"></i> Payment History</span>
                <span class="small text-muted">@Model.Entries.Count entry@(Model.Entries.Count == 1 ? "" : "ies")</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Entries.Any())
                {
                    <div class="p-4 text-muted">
                        No payment or charge history has been recorded for this booking yet.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Type</th>
                                    <th>Description</th>
                                    <th>Method</th>
                                    <th>Reference</th>
                                    <th>Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in Model.Entries)
                                {
                                    var amountClass = entry.Type switch
                                    {
                                        PaymentEntryType.Payment => "text-success",
                                        PaymentEntryType.Refund => "text-danger",
                                        _ => "text-primary"
                                    };

                                    <tr>
                                        <td class="small text-muted">@entry.ProcessedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                        <td>
                                            <span class="badge @(entry.Type == PaymentEntryType.Payment ? "bg-success" : entry.Type == PaymentEntryType.Refund ? "bg-danger" : "bg-primary")">
                                                @entry.Type
                                            </span>
                                        </td>
                                        <td>
                                            <div class="fw-semibold">@entry.Description</div>
                                            @if (!string.IsNullOrWhiteSpace(entry.MaskedCardNumber))
                                            {
                                                <div class="small text-muted">@entry.MaskedCardNumber</div>
                                            }
                                        </td>
                                        <td class="small">@entry.Method</td>
                                        <td class="small text-muted">@(entry.Reference ?? "-")</td>
                                        <td class="fw-bold @amountClass">@entry.Amount.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
