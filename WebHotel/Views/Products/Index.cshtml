@model IEnumerable<WebHotel.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <h1><i class="bi bi-box-seam"></i> Products</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Add Product
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Description</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><span class="fw-semibold">@item.Name</span></td>
                    <td><span class="badge bg-secondary">@item.Category</span></td>
                    <td class="fw-bold">@item.Price.ToString("C")</td>
                    <td class="text-muted">@(item.Description?.Length > 60 ? item.Description[..60] + "..." : item.Description)</td>
                    <td class="text-end action-links">
                        <a class="btn-action-edit" asp-action="Edit" asp-route-id="@item.Id">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a class="btn-action-detail" asp-action="Details" asp-route-id="@item.Id">
                            <i class="bi bi-eye"></i> Details
                        </a>
                        <a class="btn-action-delete" asp-action="Delete" asp-route-id="@item.Id">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
