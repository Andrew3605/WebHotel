@model WebHotel.ViewModels.RoomServiceVm
@{
    ViewData["Title"] = "Room Service";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h2><i class="bi bi-cup-hot"></i> Room Service</h2>
        <p class="text-muted mb-0">
            Booking <strong>#@Model.BookingId</strong> &mdash;
            <strong>@Model.CustomerName</strong> &mdash;
            Room <strong>@Model.RoomNumber</strong>
            <span class="ms-2 small">(@Model.CheckIn.ToString("MMM dd") &ndash; @Model.CheckOut.ToString("MMM dd, yyyy"))</span>
        </p>
    </div>
    <div class="text-end">
        <div class="small text-muted">Current Balance</div>
        <div class="fs-5 fw-bold @(Model.BalanceDue > 0 ? "text-warning" : "text-success")">
            @Model.BalanceDue.ToString("C")
        </div>
        <a asp-controller="Payments" asp-action="Statement" asp-route-bookingId="@Model.BookingId"
           class="btn btn-outline-secondary btn-sm mt-1">
            <i class="bi bi-arrow-left"></i> Back to Statement
        </a>
    </div>
</div>

@if (TempData["PaymentOk"] is string msg)
{
    <div class="alert alert-success d-flex align-items-center">
        <i class="bi bi-check-circle-fill me-2"></i> @msg
    </div>
}

<div class="card shadow-soft mb-3">
    <div class="card-body p-3">
        <div class="d-flex flex-wrap gap-2 align-items-center">
            <span class="fw-semibold me-2">Filter:</span>
            <a asp-action="Order" asp-route-bookingId="@Model.BookingId"
               class="btn btn-sm @(Model.CategoryFilter == null ? "btn-primary" : "btn-outline-primary")">
                All
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a asp-action="Order" asp-route-bookingId="@Model.BookingId" asp-route-category="@cat"
                   class="btn btn-sm @(Model.CategoryFilter == cat ? "btn-primary" : "btn-outline-primary")">
                    @cat
                </a>
            }
        </div>
    </div>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No products available@(Model.CategoryFilter != null ? " in this category" : "").
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Products" asp-action="Create">Add products</a>
        }
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var product in Model.Products)
        {
            <div class="col">
                <div class="card h-100">
                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                    {
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name"
                             style="height:160px; object-fit:cover;" />
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@product.Name</h5>
                                <span class="badge bg-secondary">@product.Category</span>
                            </div>
                            <span class="fs-5 fw-bold text-primary">@product.Price.ToString("C")</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(product.Description))
                        {
                            <p class="card-text text-muted small flex-grow-1">@product.Description</p>
                        }

                        <form asp-action="AddCharge" method="post" class="mt-auto">
                            <input type="hidden" name="BookingId" value="@Model.BookingId" />
                            <input type="hidden" name="ProductId" value="@product.Id" />
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">Qty</span>
                                <input type="number" name="Quantity" value="1" min="1" max="50" class="form-control" style="max-width:70px;" />
                                <input type="text" name="Note" class="form-control" placeholder="Note (optional)" />
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-plus-circle"></i> Add
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
