{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=WebHotelDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },

  "Smtp": {
    "Host": "localhost",
    "Port": 25,
    "EnableSsl": false,
    "FromAddress": "noreply@webhotel.local",
    "FromName": "WebHotel"
  },

  "AllowedHosts": "*"
}
